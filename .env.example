# ============================================================
# 环境变量
# 复制为 .env 并填写实际值
# ============================================================

# 数据库密码
DB_PASSWORD=your_db_password_here

# LLM API 密钥
LLM_API_KEY=your_llm_api_key_here

# JWT 密钥（生产环境务必使用随机字符串）
JWT_SECRET=your_jwt_secret_here_change_in_production
